#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
BIN_DIR="${HOME}/.local/bin"

mkdir -p "$BIN_DIR"
ln -sf "$SCRIPT_DIR/scripts/claude-mailbox.mjs" "$BIN_DIR/clauder"

printf 'Installed: %s/clauder\n\n' "$BIN_DIR"
printf 'Now open a new terminal and run:\n  clauder\n'
