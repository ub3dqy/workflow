{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/mailbox-session-register.mjs\" --project workflow --agent codex",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/mailbox-session-register.mjs\" --project workflow --agent codex",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
